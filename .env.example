# ─── OpenAI ───
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional per-step overrides (falls back to OPENAI_MODEL)
# OPENAI_AUTOPILOT_EXTRACT_MODEL=gpt-5-mini
# OPENAI_AUTOPILOT_REPLY_MODEL=gpt-5-mini
# OPENAI_CALENDAR_MODEL=gpt-5-mini

# ─── Timezone (default: America/Toronto) ───
TIMEZONE=America/Toronto

# ─── Slack (Incoming Webhook) ───
SLACK_WEBHOOK_URL=YOUR_SLACK_WEBHOOK_URL_HERE

# ─── Linear (Issue Tracker) ───
LINEAR_API_KEY=YOUR_LINEEAR_API_KEY_HERE
LINEAR_TEAM_ID=YOUR_LINEAR_TEAM_ID_HERE

# ─── SMTP (Email - optional) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM=your@email.com

# ─── Piper TTS (local, offline) ───
# PIPER_MODELS_DIR=Backend/models/piper
# PIPER_ZH_MODEL=Backend/models/piper/zh_CN-xiao_ya-medium.onnx
# PIPER_EN_MODEL=Backend/models/piper/en_US-amy-medium.onnx

# ─── RAG deployment (single-host local filesystem only) ───
# RAG_DEPLOYMENT_MODE=single-host
# RAG_STORE_DIR=Backend/rag_store

# ─── Warmup (optional — all default true/enabled) ───
# WARMUP_ENABLED=true
# Numeric values are strictly validated at startup.
# WARMUP_MAX_CONCURRENT=2   # integer >= 1
# WARMUP_TASK_TIMEOUT=60.0  # finite seconds > 0
# WARMUP_RETRIES=2          # integer >= 0; required resources only
# WARMUP_RETRY_DELAY=1.0    # finite seconds >= 0
# WARMUP_STATE_DIR=Backend/.runtime/warmup
# WARMUP_STATE_TTL_SECONDS=300.0  # finite seconds > 0
# WARMUP_STATE_HEARTBEAT_SECONDS=60.0  # finite seconds > 0 and below TTL
# WARMUP_WHISPER_ENABLED=true
# WARMUP_PIPER_ZH_ENABLED=true
# WARMUP_PIPER_EN_ENABLED=true
# WARMUP_OPENAI_ENABLED=true
# WARMUP_FAISS_ENABLED=true

# ─── HuggingFace (offline mode — bert-base-chinese is already cached) ───
HF_HUB_OFFLINE=1

# Streaming STT/TTS tuning (optional)
# WHISPER_BEAM_SIZE=1
# WHISPER_BEST_OF=1
# WHISPER_VAD_FILTER=true
# WHISPER_NO_SPEECH_THRESHOLD=0.5
# STREAM_STT_UPDATE_MS=350
# STREAM_STT_MIN_BYTES=2000
# STREAM_STT_PARTIAL_DEBOUNCE_N=2
# STREAM_STT_MIN_SPEECH_MS=350
# STREAM_STT_SILENCE_MS=900
# STREAM_STT_MAX_AUDIO_MS=25000
# STREAM_STT_ENERGY_THRESHOLD=0.02
# STREAM_DEFAULT_CHUNK_MS=80
# STREAM_TTS_WORKERS=2
# TTS_FIRST_SEGMENT_CHARS=16
# TTS_SEGMENT_MAX_CHARS=48
# TTS_MIN_PUNCT_BREAK_CHARS=8
